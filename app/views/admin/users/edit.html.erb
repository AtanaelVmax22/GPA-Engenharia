<% content_for :page_title, "Editar Usuário" %>
<div class="max-w-lg">
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <%= form_with model: [:admin, @user] do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :nome, "Nome", class: "block text-sm font-medium text-zinc-300 mb-1" %>
          <%= f.text_field :nome, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
        </div>
        <div>
          <%= f.label :email, "E-mail", class: "block text-sm font-medium text-zinc-300 mb-1" %>
          <%= f.email_field :email, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
        </div>
        <div>
          <%= f.label :telefone, "Telefone", class: "block text-sm font-medium text-zinc-300 mb-1" %>
          <%= f.text_field :telefone, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
        </div>
        <div>
          <%= f.label :role, "Perfil", class: "block text-sm font-medium text-zinc-300 mb-1" %>
          <%= f.select :role, User.roles.keys.map { |r| [r.capitalize, r] }, {},
              class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
        </div>
        <div class="flex gap-3 pt-2">
          <%= f.submit "Salvar", class: "px-6 py-2.5 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-semibold rounded-xl text-sm cursor-pointer" %>
          <%= link_to "Cancelar", admin_users_path, class: "px-6 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-xl text-sm" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
