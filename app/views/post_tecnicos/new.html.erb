<% content_for :page_title, "Novo Post Técnico" %>
<div class="max-w-2xl">
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-amber-400 mb-4">Publicar Conhecimento Técnico</h2>
    <%= form_with model: PostTecnico.new, url: post_tecnicos_path do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :titulo, "Título", class: "block text-sm font-medium text-zinc-300 mb-1" %>
          <%= f.text_field :titulo, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500", placeholder: "Manutenção preventiva realizada" %>
        </div>
        <div>
          <%= f.label :conteudo, "Conteúdo", class: "block text-sm font-medium text-zinc-300 mb-1" %>
          <%= f.text_area :conteudo, rows: 6, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500 resize-none", placeholder: "Descreva o procedimento, solução encontrada, dica técnica..." %>
        </div>
        <div>
          <%= f.label :condominio_id, "Condomínio (opcional)", class: "block text-sm font-medium text-zinc-300 mb-1" %>
          <%= f.select :condominio_id, @condominios.map { |c| [c.nome, c.id] },
              { include_blank: "Post geral (sem condomínio específico)" },
              class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
        </div>
        <div class="flex gap-3 pt-2">
          <%= f.submit "Publicar", class: "px-6 py-2.5 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-semibold rounded-xl text-sm cursor-pointer transition-colors" %>
          <%= link_to "Cancelar", post_tecnicos_path, class: "px-6 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-xl text-sm transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
