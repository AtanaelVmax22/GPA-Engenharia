<% content_for :page_title, "Novo Post" %>

<div class="max-w-lg mx-auto pb-10">

  <!-- Header fixo -->
  <div class="flex items-center gap-3 mb-4">
    <%= link_to "←", post_tecnicos_path, class: "text-zinc-400 hover:text-zinc-100 text-xl w-8" %>
    <h1 class="font-bold text-zinc-100 flex-1">Novo Post Técnico</h1>
  </div>

  <%= form_with model: PostTecnico.new, url: post_tecnicos_path, html: { enctype: "multipart/form-data" } do |f| %>

    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden space-y-0">

      <!-- Linha do usuário -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-zinc-800">
        <div class="w-9 h-9 rounded-full bg-amber-500 flex items-center justify-center text-zinc-900 font-bold text-sm flex-shrink-0">
          <%= current_user.nome.first.upcase %>
        </div>
        <p class="text-sm font-semibold text-zinc-200"><%= current_user.nome %></p>
      </div>

      <!-- Texto do post -->
      <div class="px-4 py-3 border-b border-zinc-800">
        <%= f.text_area :conteudo, rows: 4,
            placeholder: "Compartilhe uma dica técnica, procedimento ou solução...",
            class: "w-full bg-transparent text-zinc-200 placeholder-zinc-600 text-sm resize-none outline-none border-0 focus:outline-none leading-relaxed" %>
      </div>

      <!-- Título -->
      <div class="px-4 py-3 border-b border-zinc-800">
        <%= f.label :titulo, "Título (opcional)", class: "block text-xs text-zinc-600 mb-1" %>
        <%= f.text_field :titulo,
            placeholder: "Ex: Falha no portão PPA — solução",
            class: "w-full bg-transparent text-zinc-200 placeholder-zinc-600 text-sm outline-none border-0 focus:outline-none" %>
      </div>

      <!-- Condomínio -->
      <div class="px-4 py-3 border-b border-zinc-800">
        <%= f.label :condominio_id, "Condomínio (opcional)", class: "block text-xs text-zinc-600 mb-1" %>
        <%= f.select :condominio_id,
            @condominios.map { |c| [c.nome, c.id] },
            { include_blank: "Post geral" },
            class: "w-full bg-transparent text-zinc-300 text-sm outline-none border-0 focus:outline-none" %>
      </div>

      <!-- Preview das mídias selecionadas -->
      <div id="preview-container" class="hidden border-b border-zinc-800">
        <div id="preview-grid" class="grid grid-cols-3 gap-0.5 max-h-64 overflow-hidden"></div>
        <label for="midias-input" class="flex items-center justify-center gap-2 py-2 text-xs text-zinc-500 hover:text-amber-400 cursor-pointer transition-colors">
          + Adicionar mais mídias
        </label>
      </div>

      <!-- Botões de mídia -->
      <div class="px-4 py-3 flex gap-3">
        <label for="midias-input" class="flex items-center gap-2 px-4 py-2.5 bg-zinc-800 hover:bg-zinc-700 active:bg-zinc-600 rounded-xl text-sm text-zinc-300 cursor-pointer transition-colors flex-1 justify-center select-none">
          <span class="text-base">📷</span>
          <span>Foto/Vídeo</span>
        </label>
        <label for="midias-input" class="flex items-center gap-2 px-4 py-2.5 bg-zinc-800 hover:bg-zinc-700 active:bg-zinc-600 rounded-xl text-sm text-zinc-300 cursor-pointer transition-colors flex-1 justify-center select-none">
          <span class="text-base">🖼</span>
          <span>Galeria</span>
        </label>
        <%= f.file_field :midias, multiple: true, accept: "image/*,video/*",
            id: "midias-input", class: "hidden",
            onchange: "previewMidias(this)" %>
      </div>

      <!-- Botão publicar -->
      <div class="px-4 pb-4">
        <%= f.submit "Publicar",
            class: "w-full py-3 bg-amber-500 hover:bg-amber-400 active:bg-amber-600 text-zinc-900 font-bold rounded-xl text-sm cursor-pointer transition-colors" %>
      </div>

    </div>
  <% end %>
</div>

<script>
function previewMidias(input) {
  const container = document.getElementById('preview-container');
  const grid = document.getElementById('preview-grid');

  grid.innerHTML = '';

  if (input.files && input.files.length > 0) {
    container.classList.remove('hidden');

    Array.from(input.files).slice(0, 9).forEach(file => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const div = document.createElement('div');
        div.className = 'aspect-square overflow-hidden relative bg-zinc-800';
        if (file.type.startsWith('video/')) {
          const video = document.createElement('video');
          video.src = e.target.result;
          video.className = 'w-full h-full object-cover';
          video.muted = true;
          video.playsInline = true;
          const badge = document.createElement('div');
          badge.className = 'absolute bottom-1 right-1 bg-black/70 text-white text-xs px-1.5 py-0.5 rounded';
          badge.textContent = '▶';
          div.appendChild(video);
          div.appendChild(badge);
        } else {
          const img = document.createElement('img');
          img.src = e.target.result;
          img.className = 'w-full h-full object-cover';
          div.appendChild(img);
        }
        grid.appendChild(div);
      };
      reader.readAsDataURL(file);
    });
  } else {
    container.classList.add('hidden');
  }
}
</script>
