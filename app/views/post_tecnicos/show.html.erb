<% content_for :page_title, @post.titulo %>
<div class="mb-6">
  <%= link_to "← Feed Técnico", post_tecnicos_path, class: "text-sm text-zinc-500 hover:text-zinc-300" %>
</div>

<div class="max-w-3xl">
  <!-- Post -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-amber-500 flex items-center justify-center text-zinc-900 font-bold">
        <%= @post.user.nome.first.upcase %>
      </div>
      <div>
        <p class="text-sm font-semibold text-zinc-200"><%= @post.user.nome %></p>
        <p class="text-xs text-zinc-500"><%= @post.created_at.strftime("%d/%m/%Y %H:%M") %>
          <% if @post.condominio %> &mdash; <%= @post.condominio.nome %><% end %>
        </p>
      </div>
    </div>
    <h1 class="text-xl font-bold text-zinc-100 mb-4"><%= @post.titulo %></h1>
    <div class="text-sm text-zinc-300 whitespace-pre-line leading-relaxed"><%= @post.conteudo %></div>
  </div>

  <!-- Comentários -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <h2 class="font-semibold text-zinc-100 mb-4">Comentários (<%= @post.comentarios.count %>)</h2>
    <% @post.comentarios.includes(:user).order(:created_at).each do |c| %>
      <div class="flex items-start gap-3 py-3 border-b border-zinc-800 last:border-0">
        <div class="w-8 h-8 rounded-full bg-zinc-700 flex items-center justify-center text-zinc-300 text-xs font-bold">
          <%= c.user.nome.first.upcase %>
        </div>
        <div class="flex-1">
          <p class="text-xs font-semibold text-zinc-400"><%= c.user.nome %> &mdash; <%= time_ago_in_words(c.created_at) %> atrás</p>
          <p class="text-sm text-zinc-300 mt-1"><%= c.conteudo %></p>
        </div>
        <% if c.user == current_user || current_user.admin? %>
          <%= button_to "✕", post_tecnico_comentario_path(@post, c), method: :delete, class: "text-zinc-600 hover:text-red-400 text-xs bg-transparent border-0 cursor-pointer" %>
        <% end %>
      </div>
    <% end %>

    <!-- New comment -->
    <div class="mt-4 pt-4 border-t border-zinc-800">
      <%= form_with url: post_tecnico_comentarios_path(@post) do |f| %>
        <div class="flex gap-3">
          <%= f.text_area :comentario, name: "comentario[conteudo]", rows: 2,
              placeholder: "Adicionar comentário...",
              class: "flex-1 px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500 resize-none" %>
          <%= f.submit "Comentar", class: "px-4 py-2.5 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-semibold rounded-xl text-sm cursor-pointer self-end" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
