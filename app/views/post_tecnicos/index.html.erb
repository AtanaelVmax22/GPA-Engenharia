<% content_for :page_title, "Feed Técnico" %>

<div class="max-w-lg mx-auto">

  <!-- Header -->
  <div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-2">
      <span class="text-amber-400 text-lg">◈</span>
      <span class="font-bold text-zinc-100">Feed Técnico</span>
    </div>
    <%= link_to new_post_tecnico_path, class: "flex items-center gap-1.5 px-4 py-2 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-bold rounded-xl text-sm transition-colors" do %>
      <span class="text-lg leading-none">+</span> Postar
    <% end %>
  </div>

  <!-- Search -->
  <%= form_with url: post_tecnicos_path, method: :get, class: "mb-6" do |f| %>
    <div class="relative">
      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500 text-sm">⌕</span>
      <%= f.text_field :q, value: params[:q], placeholder: "Buscar posts...",
          class: "w-full pl-9 pr-4 py-2.5 bg-zinc-900 border border-zinc-800 rounded-xl text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-amber-500" %>
    </div>
  <% end %>

  <!-- Posts -->
  <div class="flex flex-col gap-8">
    <% @posts.each do |post| %>
      <article class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden shadow-lg shadow-black/30">

        <!-- Header -->
        <div class="flex items-center justify-between px-4 py-3">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-amber-500 flex items-center justify-center text-zinc-900 font-bold text-sm flex-shrink-0">
              <%= post.user.nome.first.upcase %>
            </div>
            <div>
              <p class="text-sm font-semibold text-zinc-100 leading-tight"><%= post.user.nome %></p>
              <% if post.condominio %>
                <p class="text-xs text-zinc-500"><%= post.condominio.nome %></p>
              <% end %>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs text-zinc-600"><%= time_ago_in_words(post.created_at) %> atrás</span>
            <% if post.user == current_user || current_user.admin? %>
              <%= button_to post_tecnico_path(post), method: :delete,
                  data: { confirm: "Remover post?" },
                  class: "text-zinc-600 hover:text-red-400 text-base bg-transparent border-0 cursor-pointer leading-none" do %>&#x2715;<% end %>
            <% end %>
          </div>
        </div>

        <!-- Mídias (fotos e vídeos) -->
        <% if post.midias.attached? %>
          <% midias = post.midias.to_a %>
          <% fotos  = midias.select { |m| m.content_type.start_with?("image/") } %>
          <% videos = midias.select { |m| m.content_type.start_with?("video/") } %>

          <!-- Vídeos -->
          <% videos.each do |video| %>
            <video controls muted playsinline preload="metadata"
                   data-feed-video
                   class="w-full max-h-96 bg-black object-contain">
              <source src="<%= url_for(video) %>" type="<%= video.content_type %>">
            </video>
          <% end %>

          <!-- Fotos -->
          <% if fotos.size == 1 %>
            <%= link_to post_tecnico_path(post) do %>
              <%= image_tag fotos.first, class: "w-full aspect-square object-cover" %>
            <% end %>
          <% elsif fotos.size > 1 %>
            <div class="grid grid-cols-2 gap-0.5">
              <% fotos.first(4).each_with_index do |foto, i| %>
                <div class="relative">
                  <%= image_tag foto, class: "w-full aspect-square object-cover" %>
                  <% if i == 3 && fotos.size > 4 %>
                    <div class="absolute inset-0 bg-black/60 flex items-center justify-center">
                      <span class="text-white text-2xl font-bold">+<%= fotos.size - 4 %></span>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>

        <!-- Ações -->
        <div class="px-4 pt-3 pb-1">
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-4">
              <% if post.curtido_por?(current_user) %>
                <%= button_to post_tecnico_curtida_path(post, post.curtidas.find_by(user: current_user)),
                    method: :delete, class: "flex items-center gap-1.5 text-red-500 bg-transparent border-0 cursor-pointer p-0 group" do %>
                  <span class="text-xl leading-none group-hover:scale-110 transition-transform">♥</span>
                  <span class="text-sm font-semibold"><%= post.curtidas.count %></span>
                <% end %>
              <% else %>
                <%= button_to post_tecnico_curtidas_path(post),
                    method: :post, class: "flex items-center gap-1.5 text-zinc-400 hover:text-red-500 bg-transparent border-0 cursor-pointer p-0 group" do %>
                  <span class="text-xl leading-none group-hover:scale-110 transition-transform">♡</span>
                  <span class="text-sm font-semibold"><%= post.curtidas.count %></span>
                <% end %>
              <% end %>
              <%= link_to post_tecnico_path(post), class: "flex items-center gap-1.5 text-zinc-400 hover:text-zinc-200" do %>
                <span class="text-xl leading-none">💬</span>
                <span class="text-sm font-semibold"><%= post.comentarios.count %></span>
              <% end %>
            </div>
            <span class="text-zinc-600 text-xl">🔖</span>
          </div>

          <% if post.titulo.present? %>
            <p class="text-sm font-semibold text-zinc-100 mb-0.5"><%= post.titulo %></p>
          <% end %>
          <p class="text-sm text-zinc-300 leading-relaxed">
            <span class="font-semibold text-zinc-100"><%= post.user.nome %></span>
            <%= truncate(post.conteudo, length: 120) %>
            <% if post.conteudo.length > 120 %>
              <%= link_to "mais", post_tecnico_path(post), class: "text-zinc-500 text-xs" %>
            <% end %>
          </p>

          <% if post.comentarios.count > 0 %>
            <%= link_to "Ver todos os #{post.comentarios.count} comentários", post_tecnico_path(post), class: "text-xs text-zinc-600 hover:text-zinc-400 block mt-1.5" %>
            <% post.comentarios.includes(:user).order(:created_at).last(2).each do |c| %>
              <p class="text-sm text-zinc-300 mt-1">
                <span class="font-semibold text-zinc-100"><%= c.user.nome %></span>
                <%= truncate(c.conteudo, length: 80) %>
              </p>
            <% end %>
          <% end %>

          <p class="text-xs text-zinc-700 mt-2 uppercase tracking-wide"><%= post.created_at.strftime("%d de %B") %></p>
        </div>

        <!-- Comentário rápido -->
        <div class="px-4 py-3 border-t border-zinc-800 flex items-center gap-3">
          <div class="w-7 h-7 rounded-full bg-amber-500 flex items-center justify-center text-zinc-900 font-bold text-xs flex-shrink-0">
            <%= current_user.nome.first.upcase %>
          </div>
          <%= form_with url: post_tecnico_comentarios_path(post), class: "flex-1 flex items-center gap-2" do |f| %>
            <%= f.text_field :comentario, name: "comentario[conteudo]", placeholder: "Adicionar comentário...",
                class: "flex-1 bg-transparent text-sm text-zinc-300 placeholder-zinc-600 outline-none border-0 focus:outline-none" %>
            <%= f.submit "Publicar", class: "text-xs font-bold text-amber-400 hover:text-amber-300 cursor-pointer bg-transparent border-0" %>
          <% end %>
        </div>

      </article>
    <% end %>
  </div>

  <% if @posts.empty? %>
    <div class="text-center py-20 text-zinc-600">
      <div class="text-5xl mb-4">◈</div>
      <p class="text-lg">Nenhum post ainda.</p>
      <%= link_to "Ser o primeiro a postar", new_post_tecnico_path, class: "text-amber-400 hover:text-amber-300 text-sm mt-2 inline-block" %>
    </div>
  <% end %>

  <%== pagy_nav(@pagy) if @pagy.pages > 1 rescue nil %>
</div>

<script>
(function () {
  // Tracks which video is currently playing (at most one at a time)
  let currentPlaying = null;

  // Ratio of video height that must be inside the viewport to trigger play
  const THRESHOLD = 0.6;

  // Map each video to its latest intersection ratio
  const ratioMap = new WeakMap();

  function pickBestVideo() {
    let bestVideo = null;
    let bestRatio = 0;

    document.querySelectorAll('[data-feed-video]').forEach(v => {
      const r = ratioMap.get(v) || 0;
      if (r > bestRatio) {
        bestRatio = r;
        bestVideo = v;
      }
    });

    if (bestRatio >= THRESHOLD) {
      if (currentPlaying && currentPlaying !== bestVideo) {
        currentPlaying.pause();
      }
      if (bestVideo && bestVideo !== currentPlaying) {
        bestVideo.play().catch(() => {});
        currentPlaying = bestVideo;
      }
    } else {
      if (currentPlaying) {
        currentPlaying.pause();
        currentPlaying = null;
      }
    }
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      ratioMap.set(entry.target, entry.intersectionRatio);
    });
    pickBestVideo();
  }, {
    threshold: Array.from({ length: 21 }, (_, i) => i / 20) // 0, 0.05, 0.10 … 1.0
  });

  function observeVideos() {
    document.querySelectorAll('[data-feed-video]').forEach(v => observer.observe(v));
  }

  // Observe on load and after Turbo navigations
  document.addEventListener('turbo:load', observeVideos);
  document.addEventListener('DOMContentLoaded', observeVideos);
})();
</script>
