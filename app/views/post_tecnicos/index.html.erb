<% content_for :page_title, "Feed Técnico" %>

<div class="flex items-center justify-between mb-6">
  <div></div>
  <%= link_to "+ Novo Post", new_post_tecnico_path, class: "px-4 py-2 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-semibold rounded-xl text-sm transition-colors" %>
</div>

<!-- Search -->
<div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-4 mb-6">
  <%= form_with url: post_tecnicos_path, method: :get, class: "flex gap-3" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Buscar posts técnicos...",
        class: "flex-1 px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 placeholder-zinc-500 text-sm focus:outline-none focus:border-amber-500" %>
    <%= f.submit "Buscar", class: "px-4 py-2 bg-zinc-700 hover:bg-zinc-600 text-zinc-100 rounded-xl text-sm cursor-pointer" %>
  <% end %>
</div>

<div class="space-y-4">
  <% @posts.each do |post| %>
    <div class="bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-2xl p-6 transition-colors">
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 rounded-full bg-amber-500 flex items-center justify-center text-zinc-900 font-bold text-sm flex-shrink-0">
          <%= post.user.nome.first.upcase %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap mb-1">
            <span class="text-sm font-semibold text-zinc-200"><%= post.user.nome %></span>
            <span class="text-xs text-zinc-600">&mdash;</span>
            <span class="text-xs text-zinc-500"><%= time_ago_in_words(post.created_at) %> atrás</span>
            <% if post.condominio %>
              <span class="text-xs bg-zinc-800 text-zinc-400 px-2 py-0.5 rounded"><%= post.condominio.nome %></span>
            <% end %>
          </div>
          <h3 class="font-semibold text-zinc-100 mb-2"><%= link_to post.titulo, post, class: "hover:text-amber-400 transition-colors" %></h3>
          <p class="text-sm text-zinc-400 line-clamp-3"><%= truncate(post.conteudo, length: 200) %></p>
          <div class="flex items-center gap-4 mt-3 text-xs text-zinc-600">
            <span>💬 <%= post.comentarios.count %> comentário(s)</span>
            <%= link_to "Ver post", post, class: "text-amber-400 hover:text-amber-300" %>
            <% if post.user == current_user || current_user.admin? %>
              <%= button_to "Remover", post, method: :delete,
                  data: { confirm: "Remover este post?" },
                  class: "text-red-500 hover:text-red-400 bg-transparent border-0 p-0 cursor-pointer" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
  <% if @posts.empty? %>
    <div class="text-center py-16 text-zinc-600">
      <div class="text-4xl mb-3">◈</div>
      <p>Nenhum post técnico encontrado.</p>
      <%= link_to "Publicar o primeiro", new_post_tecnico_path, class: "text-amber-400 hover:text-amber-300 text-sm mt-2 inline-block" %>
    </div>
  <% end %>
</div>

<%== pagy_nav(@pagy) if @pagy.pages > 1 rescue nil %>
