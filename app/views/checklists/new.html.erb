<% content_for :page_title, "Novo Checklist" %>
<%= link_to "← #{@condominio.nome}", @condominio, class: "text-sm text-zinc-500 hover:text-zinc-300 block mb-6" %>

<div class="max-w-2xl">
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-amber-400 mb-5">Checklist de Campo</h2>

    <%= form_with model: [@condominio, @checklist] do |f| %>
      <% if @checklist.errors.any? %>
        <div class="bg-red-900/50 border border-red-700 rounded-xl p-4 text-red-300 text-sm mb-4">
          <% @checklist.errors.full_messages.each do |msg| %><div>&bull; <%= msg %></div><% end %>
        </div>
      <% end %>

      <div class="space-y-4 mb-6">
        <div>
          <%= f.label :titulo, "Título", class: "block text-sm font-medium text-zinc-300 mb-1" %>
          <%= f.text_field :titulo, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500", placeholder: "Manutenção preventiva - #{@condominio.nome}" %>
        </div>
        <div>
          <%= f.label :data_visita, "Data/Hora da Visita", class: "block text-sm font-medium text-zinc-300 mb-1" %>
          <%= f.datetime_local_field :data_visita, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
        </div>
      </div>

      <div class="mb-6">
        <h3 class="text-sm font-medium text-zinc-300 mb-3">Itens do Checklist</h3>
        <div id="checklist-items" class="space-y-2">
          <%= f.fields_for :checklist_items do |item_f| %>
            <div class="flex items-center gap-2">
              <%= item_f.text_field :descricao, class: "flex-1 px-3 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-zinc-100 text-sm focus:outline-none focus:border-amber-500", placeholder: "Item do checklist" %>
              <%= item_f.hidden_field :ordem %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="flex gap-3">
        <%= f.submit "Criar Checklist", class: "px-6 py-2.5 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-semibold rounded-xl text-sm cursor-pointer transition-colors" %>
        <%= link_to "Cancelar", @condominio, class: "px-6 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-xl text-sm transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
