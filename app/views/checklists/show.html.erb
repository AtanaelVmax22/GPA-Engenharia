<% content_for :page_title, @checklist.titulo %>

<div class="mb-6">
  <%= link_to "← #{@checklist.condominio.nome}", @checklist.condominio, class: "text-sm text-zinc-500 hover:text-zinc-300" %>
</div>

<div class="max-w-2xl">
  <!-- Header -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6 mb-4">
    <div class="flex items-start justify-between flex-wrap gap-3 mb-4">
      <div>
        <h1 class="text-xl font-bold text-zinc-100"><%= @checklist.titulo %></h1>
        <p class="text-sm text-zinc-500 mt-1">
          <%= @checklist.condominio.nome %>
          <% if @checklist.data_visita %>
            &mdash; <%= @checklist.data_visita.strftime("%d/%m/%Y %H:%M") %>
          <% end %>
        </p>
        <p class="text-xs text-zinc-600">Técnico: <%= @checklist.user.nome %></p>
      </div>
      <%= status_badge(@checklist.status) %>
    </div>

    <!-- Progress bar -->
    <% prog = @checklist.progresso %>
    <div class="flex items-center gap-3">
      <div class="flex-1 bg-zinc-800 rounded-full h-2">
        <div class="bg-amber-500 h-2 rounded-full transition-all" style="width: <%= prog %>%"></div>
      </div>
      <span class="text-xs text-zinc-400 w-10 text-right"><%= prog %>%</span>
    </div>
  </div>

  <!-- Items -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <h2 class="font-semibold text-zinc-100 mb-4">Itens (<%= @checklist.checklist_items.where(concluido: true).count %>/<%= @checklist.checklist_items.count %>)</h2>

    <div class="space-y-2">
      <% @checklist.checklist_items.each do |item| %>
        <%= form_with url: checklist_item_path(item), method: :patch, class: "flex items-center gap-3 py-2.5 px-3 rounded-lg #{ item.concluido? ? 'bg-emerald-900/20 border border-emerald-800/30' : 'bg-zinc-800/50 border border-zinc-700/30' }" do |f| %>
          <%= f.check_box :concluido, checked: item.concluido,
              onchange: "this.form.requestSubmit()",
              class: "w-4 h-4 rounded border-zinc-600 bg-zinc-700 text-amber-500 focus:ring-amber-500 cursor-pointer" %>
          <span class="flex-1 text-sm <%= item.concluido? ? 'line-through text-zinc-500' : 'text-zinc-300' %>">
            <%= item.descricao %>
          </span>
          <% if item.concluido? %>
            <span class="text-xs text-emerald-500">✓</span>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <% if @checklist.checklist_items.empty? %>
      <p class="text-sm text-zinc-600">Nenhum item neste checklist.</p>
    <% end %>

    <!-- Concluir checklist -->
    <% if @checklist.em_andamento? && @checklist.progresso == 100 %>
      <div class="mt-6 pt-4 border-t border-zinc-800">
        <%= button_to "Marcar como Concluído", checklist_path(@checklist),
            params: { checklist: { status: "concluido" } }, method: :patch,
            class: "w-full py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-xl text-sm cursor-pointer transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
