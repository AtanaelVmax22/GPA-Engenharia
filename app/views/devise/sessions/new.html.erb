<div class="w-full max-w-sm mx-auto">
  <!-- Logo -->
  <div class="text-center mb-8">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-amber-500 mb-4">
      <span class="text-2xl font-black text-zinc-900">GPA</span>
    </div>
    <h1 class="text-2xl font-bold text-zinc-100">Bem-vindo, <span class="text-amber-400">Técnico!</span></h1>
    <p class="text-zinc-500 text-sm mt-1">Faça login para acessar o sistema.</p>
  </div>

  <!-- Card -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-8 shadow-2xl">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1.5">E-mail</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500",
              placeholder: "seu@email.com" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1.5">Senha</label>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500",
              placeholder: "••••••••" %>
        </div>

        <div class="flex items-center justify-between">
          <label class="flex items-center gap-2 text-sm text-zinc-400 cursor-pointer">
            <%= f.check_box :remember_me, class: "rounded border-zinc-700 bg-zinc-800 text-amber-500 focus:ring-amber-500" %>
            Lembrar-me
          </label>
          <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
            <%= link_to "Esqueci minha senha", new_password_path(resource_name), class: "text-sm text-amber-400 hover:text-amber-300" %>
          <% end %>
        </div>

        <%= f.submit "Entrar", class: "w-full py-3 px-4 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-bold rounded-xl transition-colors cursor-pointer mt-2" %>
      </div>
    <% end %>
  </div>

  <p class="text-center text-xs text-zinc-600 mt-6">&copy; <%= Date.today.year %> GPA Engenharia &mdash; Versão 1.0.0</p>
</div>
