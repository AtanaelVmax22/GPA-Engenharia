<%= form_with model: [@condominio || historico.condominio, historico], class: "space-y-6" do |f| %>
  <% if historico.errors.any? %>
    <div class="bg-red-900/50 border border-red-700 rounded-xl p-4 text-red-300 text-sm">
      <% historico.errors.full_messages.each do |msg| %><div>&bull; <%= msg %></div><% end %>
    </div>
  <% end %>

  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6 space-y-4">
    <h2 class="text-base font-semibold text-amber-400">Registro Técnico</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :tipo, "Tipo de Atendimento", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.select :tipo, HistoricoTecnico.tipos.keys.map { |t| [t.humanize, t] },
            {}, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div>
        <%= f.label :status, "Status", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.select :status, HistoricoTecnico.statuses.keys.map { |s| [s.humanize, s] },
            {}, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :titulo, "Título", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :titulo, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500", placeholder: "Manutenção preventiva realizada" %>
      </div>
      <div>
        <%= f.label :equipamento_id, "Equipamento (opcional)", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.select :equipamento_id,
            ((@condominio || historico.condominio)&.equipamentos&.map { |e| [e.nome, e.id] } || []),
            { include_blank: "Nenhum / Geral" },
            class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div>
        <%= f.label :data_atendimento, "Data/Hora", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.datetime_local_field :data_atendimento, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :descricao, "Descrição do Serviço", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_area :descricao, rows: 5, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500 resize-none", placeholder: "Descreva o serviço realizado..." %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :pecas_utilizadas, "Peças Utilizadas", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_area :pecas_utilizadas, rows: 2, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500 resize-none", placeholder: "Ex: Óleo lubrificante - 1 unidade" %>
      </div>
    </div>
  </div>

  <div class="flex gap-3">
    <%= f.submit historico.new_record? ? "Registrar Atendimento" : "Salvar Alterações",
        class: "px-6 py-2.5 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-semibold rounded-xl text-sm cursor-pointer transition-colors" %>
    <%= link_to "Cancelar", :back, class: "px-6 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-xl text-sm transition-colors" %>
  </div>
<% end %>
