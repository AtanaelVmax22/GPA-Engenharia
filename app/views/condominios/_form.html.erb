<%= form_with model: condominio, class: "space-y-6" do |f| %>
  <% if condominio.errors.any? %>
    <div class="bg-red-900/50 border border-red-700 rounded-xl p-4 text-red-300 text-sm">
      <% condominio.errors.full_messages.each do |msg| %>
        <div>&bull; <%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <!-- Informações principais -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-amber-400 mb-4">Informações do Condomínio</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="md:col-span-2">
        <%= f.label :nome, "Nome do Condomínio", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :nome, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 placeholder-zinc-500 text-sm focus:outline-none focus:border-amber-500", placeholder: "Ed. Solar das Flores" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :endereco, "Endereço", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :endereco, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div>
        <%= f.label :bairro, "Bairro", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :bairro, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div>
        <%= f.label :cidade, "Cidade", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :cidade, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div>
        <%= f.label :estado, "Estado", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :estado, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500", placeholder: "SP" %>
      </div>
      <div>
        <%= f.label :cep, "CEP", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :cep, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div>
        <%= f.label :unidades, "Nº de Unidades", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.number_field :unidades, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div>
        <%= f.label :status, "Status", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.select :status, Condominio.statuses.keys.map { |s| [s.humanize, s] },
            {}, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
    </div>
  </div>

  <!-- Síndico -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-amber-400 mb-4">Dados do Síndico</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <%= f.label :sindico_nome, "Nome", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :sindico_nome, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div>
        <%= f.label :sindico_telefone, "Telefone", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :sindico_telefone, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
      <div>
        <%= f.label :sindico_email, "E-mail", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.email_field :sindico_email, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500" %>
      </div>
    </div>
  </div>

  <!-- Observações -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-amber-400 mb-4">Observações</h2>
    <%= f.text_area :observacoes, rows: 4, class: "w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-xl text-zinc-100 text-sm focus:outline-none focus:border-amber-500 resize-none", placeholder: "Informações adicionais, particularidades do local..." %>
  </div>

  <div class="flex gap-3">
    <%= f.submit condominio.new_record? ? "Cadastrar Condomínio" : "Salvar Alterações",
        class: "px-6 py-2.5 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-semibold rounded-xl text-sm cursor-pointer transition-colors" %>
    <%= link_to "Cancelar", condominios_path, class: "px-6 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-xl text-sm transition-colors" %>
  </div>
<% end %>
